{
  "expo": {
    "name": "InTracker UFC",
    "slug": "intracker-ufc",
    "backgroundColor": "#f4f7f5",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reuse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "config": {
        "googleMapsApiKey": "AIzaSyBJYMSpc_CZLfcxF2TeuVMBk1JO48Wxbqc"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.pedrot2910.ReUse",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "O InTracker usa sua localização para mostrar sua posição no mapa em relação ao ônibus."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "backgroundColor": "#f4f7f5",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBJYMSpc_CZLfcxF2TeuVMBk1JO48Wxbqc"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ufcsobral.intracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "@maplibre/maplibre-react-native",
      "expo-dev-client",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6736536-92e6-4005-924c-81cd5fa2cd9a"
      },
      "expo-navigation-bar": {
        "enforceContrast": false,
        "style": "light",
        "hidden": true
      }
    },
    "owner": "pedrot2910"
  }
}
